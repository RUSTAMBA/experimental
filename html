<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Поиск самокатов — Склад</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <canvas id="scooterCanvas" aria-hidden="true"></canvas>

    <div class="container">
        <h1>Поиск номеров самокатов</h1>

        <div class="card search-card">
            <h3>🔎 Поиск номера</h3>
            <div class="search-input-wrap">
                <input id="numberInput" placeholder="Введите номер..." autocomplete="off">
            </div>
            <button id="searchBtn">Найти</button>
            <div id="numberResult" class="result"></div>
        </div>

        <div class="card">
            <h3>🏠 Поиск по комнате</h3>
            <select id="roomSelect">
                <option value="">Загрузка комнат...</option>
            </select>
            <button id="roomBtn">Показать</button>
            <div id="roomResult" class="list"></div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
